// =============================================================================
// Select — NDS Design Library v1.0
// =============================================================================

.select {
  position: relative;
  width: 100%;

  // Trigger
  &__trigger {
    @include flex-between;
    width: 100%;
    border: 1px solid var(--color-border-input-default);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-input-default);
    padding: 0 var(--spacing-4);
    gap: var(--spacing-3);
    cursor: pointer;
    transition: border-color var(--transition-base);
    box-sizing: border-box;

    &:focus,
    &[aria-expanded="true"] {
      border-color: var(--color-border-input-focus);
      outline: none;
      box-shadow: 0 0 0 3px rgba(0, 122, 252, 0.12);
    }
  }

  // Sizes
  &--sm .select__trigger { height: 32px; font-size: var(--font-size-sm); }
  &--md .select__trigger { height: 40px; font-size: var(--font-size-md); }
  &--lg .select__trigger { height: 48px; font-size: var(--font-size-lg); }

  &__value {
    flex: 1;
    min-width: 0;
    @include ellipsis(1);
    font-size: inherit;
    color: var(--color-text-primary);
    text-align: left;

    &--placeholder { color: var(--color-text-tertiary); }
  }

  &__arrow {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--color-icon-secondary);
    transition: transform var(--transition-base);

    .select__trigger[aria-expanded="true"] & {
      transform: rotate(180deg);
    }
  }

  // Dropdown
  &__dropdown {
    position: absolute;
    top: calc(100% + var(--spacing-1));
    left: 0;
    right: 0;
    background-color: var(--color-bg-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    z-index: var(--z-dropdown);
    overflow: hidden;
    max-height: 280px;
    overflow-y: auto;
    @include scrollbar-hidden;
  }

  // Option
  &__option {
    @include flex-between;
    padding: var(--spacing-3) var(--spacing-4);
    font-size: var(--font-size-md);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background-color var(--transition-base);
    gap: var(--spacing-3);

    &:hover,
    &--focused { background-color: var(--color-bg-subtle); }

    &--selected {
      background-color: var(--primitive-green-50);
      color: var(--color-text-brand);
      font-weight: var(--font-weight-medium);
    }

    &--disabled {
      color: var(--color-text-disabled);
      pointer-events: none;
    }
  }

  &__option-check {
    width: 16px;
    height: 16px;
    color: var(--primitive-green-500);
    flex-shrink: 0;
    opacity: 0;

    .select__option--selected & { opacity: 1; }
  }

  &__group-title {
    padding: var(--spacing-3) var(--spacing-4) var(--spacing-1);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    border-top: 1px solid var(--color-border-subtle);

    &:first-child { border-top: none; }
  }

  // States
  &--error .select__trigger {
    border-color: var(--color-border-input-error);
  }

  &--disabled {
    pointer-events: none;

    .select__trigger {
      background-color: var(--color-bg-input-disabled);
      color: var(--color-text-disabled);
    }
  }

  // Multi-select tags
  &__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
    flex: 1;
    min-width: 0;
    padding: var(--spacing-1) 0;
  }
}
