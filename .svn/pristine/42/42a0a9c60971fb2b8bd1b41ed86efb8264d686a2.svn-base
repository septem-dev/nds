// =============================================================================
// List — NDS Design Library v1.0
// =============================================================================

.list {
  display: flex;
  flex-direction: column;
  width: 100%;

  // List item
  &__item {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding: var(--spacing-4) var(--spacing-6);
    border-bottom: 1px solid var(--color-border-subtle);
    transition: background-color var(--transition-base);
    cursor: default;

    &:last-child { border-bottom: none; }

    &--clickable {
      cursor: pointer;
      &:hover { background-color: var(--color-bg-subtle); }
      &:active { background-color: var(--color-bg-muted); }
    }

    &--selected {
      background-color: var(--primitive-green-50);
    }

    &--disabled {
      opacity: 0.5;
      pointer-events: none;
    }
  }

  // Leading area (icon / avatar / checkbox)
  &__leading {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: var(--color-icon-secondary);
  }

  // Content area
  &__content {
    flex: 1;
    min-width: 0;
  }

  &__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
    @include ellipsis(1);
  }

  &__subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-top: var(--spacing-1);
    @include ellipsis(1);
  }

  // Trailing area (badge / icon / action)
  &__trailing {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    color: var(--color-icon-tertiary);
  }

  // Section header
  &__section-header {
    padding: var(--spacing-3) var(--spacing-6);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    background-color: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  // Sizes
  &--sm .list__item  { padding: var(--spacing-3) var(--spacing-4); }
  &--lg .list__item  { padding: var(--spacing-6) var(--spacing-8); }

  // No dividers
  &--flush .list__item { border-bottom: none; }

  // Ordered / Numbered
  &--ordered {
    counter-reset: list-counter;

    .list__item {
      counter-increment: list-counter;

      &::before {
        content: counter(list-counter);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
        color: var(--color-text-tertiary);
        min-width: 20px;
        flex-shrink: 0;
      }
    }
  }
}
