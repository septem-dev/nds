// =============================================================================
// Statusbar — NDS Design Library v1.0
// =============================================================================

.statusbar {
  display: flex;
  align-items: center;
  gap: var(--spacing-2);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);

  // Dot indicator
  &__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  // Label
  &__label { color: var(--color-text-secondary); }

  // Status variants
  &--default  { .statusbar__dot { background-color: var(--color-border-default); } }
  &--active   { .statusbar__dot { background-color: var(--primitive-green-500); } .statusbar__label { color: var(--primitive-green-700); } }
  &--inactive { .statusbar__dot { background-color: var(--primitive-gray-400); } }
  &--pending  { .statusbar__dot { background-color: var(--primitive-orange-500); } .statusbar__label { color: var(--primitive-orange-500); } }
  &--error    { .statusbar__dot { background-color: var(--primitive-red-500); }   .statusbar__label { color: var(--primitive-red-600); } }
  &--info     { .statusbar__dot { background-color: var(--primitive-blue-500); }  .statusbar__label { color: var(--primitive-blue-700); } }

  // Bar / progress statusbar
  &--bar {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-2);
    width: 100%;

    .statusbar__header {
      @include flex-between;
      width: 100%;
    }

    .statusbar__track {
      width: 100%;
      height: 6px;
      background-color: var(--color-bg-muted);
      border-radius: var(--radius-full);
      overflow: hidden;
    }

    .statusbar__fill {
      height: 100%;
      border-radius: var(--radius-full);
      background-color: var(--primitive-green-500);
      transition: width var(--transition-slow);
    }

    &.statusbar--error   .statusbar__fill { background-color: var(--primitive-red-500); }
    &.statusbar--pending .statusbar__fill { background-color: var(--primitive-orange-500); }
  }

  // Tag style
  &--tag {
    display: inline-flex;
    padding: var(--spacing-1) var(--spacing-3);
    border-radius: var(--radius-full);

    &.statusbar--active   { background-color: var(--primitive-green-50); }
    &.statusbar--pending  { background-color: var(--primitive-orange-50); }
    &.statusbar--error    { background-color: var(--primitive-red-50); }
    &.statusbar--info     { background-color: var(--primitive-blue-50); }
    &.statusbar--inactive { background-color: var(--color-bg-subtle); }
  }
}
